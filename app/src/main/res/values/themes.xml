<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BiodivRun" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Forme à coins arrondis pour les ImageView (thumbnails de liste) -->
    <style name="RoundedThumbnail" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <style name="Theme.BiodivRun" parent="Base.Theme.BiodivRun" />

    <!-- Thème spécifique au splash screen au lancement de l'app -->
    <!-- Thème de splash, basé sur la lib AndroidX SplashScreen -->
    <style name="Theme.BiodivRun.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/transparent_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.BiodivRun</item>
    </style>

</resources>