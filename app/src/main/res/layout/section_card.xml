<?xml version="1.0" encoding="utf-8"?>
<!--
    Template d'une carte de section (utilisée dans la fiche détail).

    Le code Java inflate ce fichier autant de fois que nécessaire (une fois par
    champ texte à afficher pour l'espèce courante) et l'ajoute au container
    "container_sections" de activity_detail.xml.

    IDs internes :
    - iv_section_icon  : icône optionnelle à gauche du titre (gone par défaut)
    - tv_section_title : libellé court de la section (ex : "Description")
    - tv_section_body  : le contenu (texte long)

    POUR UTILISER L'ICÔNE (optionnel) :
    Par défaut iv_section_icon est masquée (visibility="gone"), donc rien ne
    s'affiche. Pour montrer une icône dans une section, faire en Java :

        ImageView icon = card.findViewById(R.id.iv_section_icon);
        icon.setImageResource(R.drawable.ic_eco);  // icône Material à importer
        icon.setVisibility(View.VISIBLE);

    Les icônes vectorielles peuvent être importées depuis Android Studio via :
        clic droit sur res/drawable -> New -> Vector Asset -> Clip Art
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@android:color/white"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Ligne titre (avec ImageView prête pour une icône future) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/iv_section_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null"
                android:visibility="gone"
                app:tint="@color/primary"
                tools:visibility="visible"
                tools:src="@android:drawable/ic_dialog_info" />

            <TextView
                android:id="@+id/tv_section_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                tools:text="Description" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_section_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/on_background"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp"
            tools:text="Ce tout petit oiseau brun se reconnaît à son bec et son masque rouges. Il possède également une tâche rose ventrale." />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>