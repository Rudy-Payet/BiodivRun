<?xml version="1.0" encoding="utf-8"?>
<!--
    Item de liste réutilisable.
    Structure : thumbnail + titre + sous-titre + badge + chevron.
    Utilisé pour la liste des espèces (V1), prévu aussi pour les signalements
    de déchets (V3) ou toute autre liste avec ce pattern.

    IDs génériques (le code Java se charge de remplir avec les bonnes données) :
    - iv_thumbnail   : l'image
    - tv_title       : ligne principale (ex : "Tortue verte")
    - tv_subtitle    : ligne secondaire (ex : "Chelonia mydas")
    - tv_badge       : étiquette de statut (couleur appliquée dynamiquement)
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="14dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@android:color/white"
    app:rippleColor="@color/ripple_card"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Image / thumbnail avec coins arrondis -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_thumbnail"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop"
            android:background="@color/primary_light"
            android:contentDescription="@string/cd_item_image"
            app:shapeAppearanceOverlay="@style/RoundedThumbnail"
            tools:src="@tools:sample/avatars" />

        <!-- Bloc texte -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_background"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Bec rose" />

            <!-- Sous-titre : italique + couleur vert subtil -->
            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/subtitle_green"
                android:textSize="13sp"
                android:textStyle="italic"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Estrilda astrild" />

            <!-- Badge (couleur fond + texte appliquée dynamiquement en Java) -->
            <TextView
                android:id="@+id/tv_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_badge"
                android:backgroundTint="@color/status_protected_bg"
                android:textColor="@color/status_protected"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:textAllCaps="true"
                tools:text="Préoccupation mineure (LC)" />

        </LinearLayout>

        <!-- Chevron de fin avec un peu d'air à gauche -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_chevron_right"
            android:contentDescription="@null"
            app:tint="@color/on_background_muted" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>