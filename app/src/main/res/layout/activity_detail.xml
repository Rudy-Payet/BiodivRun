<?xml version="1.0" encoding="utf-8"?>
<!--
    Écran Détail (fiche espèce) — V1

    Structure :
    - Toolbar avec flèche retour
    - Image hero
    - Bloc d'en-tête : titre + sous-titre + 2 badges (statut + UICN)
    - Container vertical qui contient N cartes de section, remplies en Java

    Le container "container_sections" est vide dans le XML. Le code Java
    inflate dedans autant de copies de section_card.xml que nécessaire (1 par
    champ texte à afficher). Si un champ est vide, on n'ajoute pas la carte.


    ALTERNATIVE — si Max préfère utiliser une ListView (plus simple à coder
    mais rendu plus basique), il peut remplacer le container par ceci :

        <ListView
            android:id="@+id/lv_sections"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp" />

    Et côté Java (4 lignes) :
        List<String> sections = new ArrayList<>();
        if (description != null) sections.add("Description\n" + description);
        if (habitat != null)     sections.add("Habitat\n"     + habitat);
        lvSections.setAdapter(new ArrayAdapter<>(
            this, android.R.layout.simple_list_item_1, sections));
    -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.DetailActivity"
    android:id="@+id/main">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="@string/detail_title"
        app:titleTextColor="@color/on_primary"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/on_primary"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Image hero -->
            <ImageView
                android:id="@+id/iv_hero"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:scaleType="centerCrop"
                android:background="@color/primary_light"
                android:contentDescription="@string/cd_item_image"
                tools:src="@tools:sample/backgrounds/scenic" />

            <!-- Bloc d'en-tête -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@android:color/white">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_background"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    tools:text="Bec rose" />

                <TextView
                    android:id="@+id/tv_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/on_background_muted"
                    android:textSize="15sp"
                    android:textStyle="italic"
                    tools:text="Astrild ondulé" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_badge_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_badge"
                        android:backgroundTint="@color/on_background_muted"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:textAllCaps="true"
                        tools:text="Protégée" />

                    <TextView
                        android:id="@+id/tv_badge_uicn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:background="@drawable/bg_badge"
                        android:backgroundTint="@color/on_background_muted"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:textAllCaps="true"
                        tools:text="LC" />

                </LinearLayout>

            </LinearLayout>

            <!-- ▼ Container des sections (rempli dynamiquement par Java) ▼ -->
            <LinearLayout
                android:id="@+id/container_sections"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:orientation="vertical" />
            <!-- ▲ Java y inflate des copies de section_card.xml ▲ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:contentDescription="@null"
                android:visibility="gone"
                app:tint="@color/primary"
                tools:visibility="visible"
                tools:src="@android:drawable/ic_dialog_info" />

            <TextView
                android:id="@+id/tv_section_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:textAllCaps="true"
                tools:text="Description" />

            </LinearLayout>
            <TextView
                android:id="@+id/tv_section_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/on_background"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                tools:text="Ce tout petit oiseau brun se reconnaît à son bec et son masque rouges. Il possède également une tâche rose ventrale." />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@null"
                    android:visibility="gone"
                    app:tint="@color/primary"
                    tools:visibility="visible"
                    tools:src="@android:drawable/ic_dialog_info" />

                <TextView
                    android:id="@+id/tv_section_env"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true"
                    tools:text="Environnement" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_section_habitat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/on_background"
                android:textSize="14sp"
                android:lineSpacingExtra="3dp"
                tools:text="habitat du oiso" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>