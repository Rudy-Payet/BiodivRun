<?xml version="1.0" encoding="utf-8"?>
<!--
    Écran d'accueil (V1) — vidéo plein écran en fond

    Structure en 3 couches (FrameLayout) :
      1. VideoView : vidéo en boucle silencieuse. Sa taille est ajustée
         en Java au démarrage pour qu'elle déborde et remplisse l'écran.
      2. View overlay : voile noir 50% pour assombrir et lisibilité
      3. ConstraintLayout : tout le contenu interactif (textes, bouton, slider)

    La vidéo doit être placée dans res/raw/paysages_reunion.mp4

    Pas de Toolbar : UX immersive, l'utilisateur arrive direct sur le paysage.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/on_background"
    android:clipChildren="true"
    tools:context=".ui.MainActivity">

    <!-- ▼ COUCHE 1 : Vidéo en arrière-plan (centrée, sera redimensionnée en Java) ▼ -->
    <VideoView
        android:id="@+id/video_background"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center" />

    <!-- ▼ COUCHE 2 : Voile sombre pour lisibilité (50% noir) ▼ -->
    <View
        android:id="@+id/video_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000" />

    <!-- ▼ COUCHE 3 : Tout le contenu interactif ▼ -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Titre principal (blanc) -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="60dp"
            android:text="@string/home_title"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="6"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Sous-titre (blanc 80%) -->
        <TextView
            android:id="@+id/tv_tagline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="12dp"
            android:text="@string/home_tagline"
            android:textColor="#CCFFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="6"
            app:layout_constraintTop_toBottomOf="@id/tv_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Bloc de réglage du rayon en bas -->
        <LinearLayout
            android:id="@+id/layout_radius"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="40dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Ligne label + valeur -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/search_radius"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/tv_radius_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="4"
                    tools:text="2,5 km" />

            </LinearLayout>

            <!-- Slider -->
            <com.google.android.material.slider.Slider
                android:id="@+id/slider_radius"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:valueFrom="0.5"
                android:valueTo="10.0"
                android:value="2.5"
                android:stepSize="0.5"
                app:thumbColor="@color/scan_button"
                app:trackColorActive="@color/scan_button"
                app:trackColorInactive="#4DFFFFFF" />

            <!-- Min / Max -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="-4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/radius_min"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:textColor="#E6FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/radius_max"
                    android:letterSpacing="0.02"
                    android:textStyle="bold"
                    android:textColor="#E6FFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Gros bouton rouge circulaire, centré dans l'espace restant -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_scan"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/scan_zone"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:cornerRadius="110dp"
            app:icon="@drawable/ic_scan"
            app:iconGravity="top"
            app:iconPadding="12dp"
            app:iconSize="56dp"
            app:backgroundTint="@color/scan_button"
            android:textColor="@color/on_scan_button"
            app:rippleColor="@color/scan_button_ripple"
            android:paddingTop="46dp"
            android:paddingBottom="8dp"
            app:elevation="8dp"
            app:layout_constraintTop_toBottomOf="@id/tv_tagline"
            app:layout_constraintBottom_toTopOf="@id/layout_radius"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Overlay de chargement (visible pendant le scan, masqué par défaut) -->
    <include
        android:id="@+id/scan_loader"
        layout="@layout/view_scan_loading"
        android:visibility="gone" />

</FrameLayout>