<?xml version="1.0" encoding="utf-8"?>
<!--
    Marqueur de carte rond : fond blanc, bordure colorée appliquée au
    runtime selon le code UICN de l'espèce (via GradientDrawable.setStroke).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@android:color/white" />
    <stroke
        android:width="4dp"
        android:color="@color/uicn_lc" />
    <size
        android:width="28dp"
        android:height="28dp" />
</shape>